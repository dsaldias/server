input NewRol {
  nombre: String!
  descripcion: String
  jerarquia: Int = 1
  permisos: [String!]!
  menus: [Int!]!
}
input UpdateRol {
  id: ID!
  nombre: String!
  descripcion: String
  jerarquia: Int = 1
  permisos: [String!]!
  menus: [Int!]!
}

