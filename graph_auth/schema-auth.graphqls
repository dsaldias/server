  documento: String
  celular: String
  correo: String
  sexo: String
  direccion: String
  username: String!
  password: String
  foto64: String
  latitud: Float
  longitud: Float
  roles: [RolUnidad!]!
  permisos_sueltos: [String!]!
  menus_sueltos: [ID!]!
}

